#!/usr/bin/env python3
import sys
import subprocess
import os
import re

LATEXINDENT = os.environ.get(
    "LITERATE_R_LATEXINDENT",
    "latexindent"
)

def find_chunks(lines):
    """Identifies Rnoweb, Rmd, and YAML blocks."""
    protected = []
    total = len(lines)
    i = 0

    # 1. YAML Header
    if total > 0 and lines[0].strip() == '---':
        for j in range(1, total):
            if lines[j].strip() == '---':
                protected.append((0, j))
                i = j + 1
                break

    # 2. R Chunks
    while i < total:
        line = lines[i].rstrip()
        # Rnoweb (<<...>>= to @)
        if re.match(r'^<<.*>>=', line):
            start = i
            for j in range(i + 1, total):
                if re.match(r'^@\s*$', lines[j].rstrip()):
                    protected.append((start, j))
                    i = j
                    break
        # R Markdown (```r to ```)
        elif re.match(r'^```\s*\{?[rR]', line):
            start = i
            for j in range(i + 1, total):
                if lines[j].rstrip() == '```':
                    protected.append((start, j))
                    i = j
                    break
        i += 1
    return protected

def main():
    content = sys.stdin.read()
    if not content.strip():
        sys.stdout.write(content)
        return

    lines = content.splitlines()
    ranges = find_chunks(lines)

    if not ranges:
        result = subprocess.run(
            [LATEXINDENT, '-g', '/dev/null', '-y', 'defaultIndent:"  ",noAdditionalIndent:multicols:1,indentPreamble:1,indentRules:item:"  "'],
            input=content, capture_output=True, text=True
        )
        sys.stdout.write(result.stdout)
        return

    # Phase 1: Replace chunks with dummy LaTeX commands
    placeholders = {}
    temp_lines = []
    last_idx = 0

    for idx, (start, end) in enumerate(ranges):
        temp_lines.extend(lines[last_idx:start])
        key = f"LSPCHUNKINTERNAL{idx}"
        placeholders[key] = "\n".join(lines[start:end+1])
        temp_lines.append(f"\\{key}")
        last_idx = end + 1

    temp_lines.extend(lines[last_idx:])

    # Phase 2: Run latexindent
    processed_input = "\n".join(temp_lines)
    result = subprocess.run(
        [LATEXINDENT, '-g', '/dev/null', '-y', 'defaultIndent:"  ",noAdditionalIndent:multicols:1,indentPreamble:1,indentRules:item:"  "'],
        input=processed_input, capture_output=True, text=True
    )

    if result.returncode != 0:
        sys.stdout.write(content)
        return

    formatted_output = result.stdout

    # Phase 3: Restore original chunks and STRIP leading indentation
    for key, original_block in placeholders.items():
        pattern = re.compile(r'^[ \t]*\\' + re.escape(key) + r'$', re.MULTILINE)
        formatted_output = pattern.sub(lambda m: original_block, formatted_output)

    sys.stdout.write(formatted_output)

if __name__ == '__main__':
    main()

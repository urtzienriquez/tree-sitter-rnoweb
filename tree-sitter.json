{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "rnoweb",
      "camelcase": "yes",
      "title": "Rnoweb",
      "scope": "source.rnoweb",
      "file-types": [
        "rnoweb",
        "Rnw"
      ],
      "injection-regex": "^rnoweb$",
      "class-name": "TreeSitterRnoweb"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "parser for R noweb ",
    "authors": [
      {
        "name": "Urtzi Enriquez",
        "email": "uenriquez@proton.me",
        "url": ""
      }
    ],
    "links": {
      "repository": "https://github.com/urtzienriquez/tree-sitter-rnoweb",
      "funding": ""
    }
  },
  "bindings": {
    "c": true,
    "go": false,
    "java": false,
    "node": true,
    "python": false,
    "rust": true,
    "swift": false,
    "zig": false
  }
}
